# Shared secret - the hooks and the local Discord client must send this exact value.
# Generate one with: python -c "from nanoid import generate; print(generate(size=30))"
BRIDGE_TOKEN=replace-with-a-nanoid-30-secret
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8787
# Drop a session if no hook fires for this long (seconds). Covers crashed/killed CLIs.
BRIDGE_SESSION_TIMEOUT=1800
# How often to re-push a snapshot so token counts refresh and dead sessions clear.
BRIDGE_HEARTBEAT=15
BRIDGE_LOG_LEVEL=INFO
