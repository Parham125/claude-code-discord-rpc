# Discord application id from https://discord.com/developers/applications (General Information page).
DISCORD_APP_ID=000000000000000000
# The bridge's reachable address and port (the server/container running the bridge).
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787
# Must match BRIDGE_TOKEN on the bridge.
BRIDGE_TOKEN=replace-with-the-same-nanoid-30-secret
# Art asset key uploaded under the Discord app's Rich Presence > Art Assets.
DISCORD_LARGE_IMAGE=claude
LOG_LEVEL=INFO
